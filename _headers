# HEADERS DE SÉCURITÉ MILLIONNAIRE DE CŒUR
# Protection maximale pour le site et les visiteurs

# ─── Headers globaux (toutes les pages) ───
/*
  # Anti-clickjacking : empêche l'intégration du site dans des iframes malveillantes
  X-Frame-Options: DENY
  Content-Security-Policy: frame-ancestors 'none'
  
  # Protection XSS (Cross-Site Scripting)
  X-XSS-Protection: 1; mode=block
  X-Content-Type-Options: nosniff
  
  # Politique de référent : équilibre entre vie privée et compatibilité
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Permissions : bloquer caméra, micro, géolocalisation par défaut
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(self), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  
  # Content Security Policy : autorise uniquement vos ressources + Stripe/Cal.com
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://js.stripe.com https://app.cal.com https://web3forms.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.stripe.com https://api.web3forms.com https://app.cal.com; frame-src https://js.stripe.com https://app.cal.com; object-src 'none'; base-uri 'self'; form-action 'self' https://api.web3forms.com;
  
  # Force HTTPS (si quelqu'un tente HTTP, redirection automatique)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  
  # Cache des polices (1 an - elles ne changent jamais)
  Cache-Control: public, max-age=31536000, immutable

# ─── Polices locales : cache agressif ───
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# ─── Pages HTML : pas de cache (pour voir les mises à jour immédiatement) ───
/*.html
  Cache-Control: no-cache, must-revalidate

# ─── Fichiers sensibles : bloquer l'accès ───
/.git/*
  X-Robots-Tag: noindex, nofollow
  
# ─── API/Formulaires : protection CSRF additionnelle ───
/contact-*
  X-Content-Type-Options: nosniff
  Referrer-Policy: same-origin
